<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EDEEFF"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Titel -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Neuen Termin erstellen"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginBottom="32dp" />

        <!-- Gastgeber Label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gastgeber"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginBottom="16dp" />

        <!-- Gastgeber Chips -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Robin"
                android:background="@drawable/badge_background"
                android:textColor="#000000"
                android:paddingVertical="4dp"
                android:paddingHorizontal="12dp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Maria"
                android:background="@drawable/badge_background"
                android:textColor="#000000"
                android:paddingVertical="4dp"
                android:paddingHorizontal="12dp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Jenny"
                android:background="@drawable/badge_background"
                android:textColor="#000000"
                android:paddingVertical="4dp"
                android:paddingHorizontal="12dp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Jakob"
                android:background="@drawable/badge_background"
                android:textColor="#000000"
                android:paddingVertical="4dp"
                android:paddingHorizontal="12dp"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lukas"
                android:background="@drawable/badge_background"
                android:textColor="#000000"
                android:paddingVertical="4dp"
                android:paddingHorizontal="12dp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hannah"
                android:background="@drawable/badge_background"
                android:textColor="#000000"
                android:paddingVertical="4dp"
                android:paddingHorizontal="12dp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Simon"
                android:background="@drawable/badge_background"
                android:textColor="#000000"
                android:paddingVertical="4dp"
                android:paddingHorizontal="12dp" />

        </LinearLayout>

        <!-- Gastgeber auslosen Button -->
        <Button
            android:id="@+id/btnGastgeberAuslosen"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Gastgeber auslosen"
            android:textColor="#000000"
            android:backgroundTint="#FFFFFF"
            app:cornerRadius="12dp"
            app:strokeColor="#CCCCCC"
            app:strokeWidth="1dp"
            android:layout_marginBottom="32dp" />

        <!-- Datum & Uhrzeit -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="32dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Uhrzeit"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/etUhrzeit"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="Uhrzeit eingeben"
                    android:padding="12dp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Datum"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#000000"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/etDatum"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="Datum eingeben"
                    android:padding="12dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Spiele Label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Spiele"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#000000"
            android:layout_marginBottom="16dp" />

        <!-- Spiele wählen Button -->
        <Button
            android:id="@+id/btnSpieleWaehlen"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Spiele wählen"
            android:textColor="#000000"
            android:backgroundTint="#FFFFFF"
            app:cornerRadius="12dp"
            app:strokeColor="#CCCCCC"
            app:strokeWidth="1dp"
            android:layout_marginBottom="64dp" />

        <!-- Termin erstellen Button -->
        <Button
            android:id="@+id/btnTerminErstellen"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Termin erstellen"
            android:textColor="#FFFFFF"
            android:backgroundTint="#05031C"
            app:cornerRadius="12dp" />

    </LinearLayout>

</ScrollView>